{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/claude-notify.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/dotfiles/claude/claude-notify.sh"
          }
        ]
      }
    ]
  }
}
