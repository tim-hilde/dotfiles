{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.7.5",
    "@mohak34/opencode-notifier@0.2.3",
    "@tarquinen/opencode-dcp@3.1.9",
    "superpowers@git+https://github.com/obra/superpowers.git#v5.0.7",
    "@slkiser/opencode-quota@3.1.2"
  ],
  "mcp": {
    "langfuse-docs": {
      "url": "https://langfuse.com/api/mcp",
      "type": "remote",
      "enabled": false
    },
    "pipecat-docs": {
      "url": "https://daily-docs.mcp.kapa.ai",
      "type": "remote",
      "enabled": false
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": false,
      "type": "local"
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "Gemma 4"
        }
      }
    }
  },
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": false,
      "enabledProviders": "auto",
      "formatStyle": "classic",
      "percentDisplayMode": "used"
    }
  }
}
