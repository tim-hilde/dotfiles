{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0",
    "@mohak34/opencode-notifier@0.2.4",
    "@tarquinen/opencode-dcp@3.1.9",
    "superpowers@git+https://github.com/obra/superpowers.git#v5.1.0",
    "opencode-update-notifier"
  ],
  "mcp": {
    "langfuse-docs": {
      "url": "https://langfuse.com/api/mcp",
      "type": "remote",
      "enabled": false
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp",
      "type": "remote",
      "enabled": true
    },
    "pipecat-docs": {
      "url": "https://daily-docs.mcp.kapa.ai",
      "type": "remote",
      "enabled": false
    },
    "pencil": {
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": false,
      "type": "local"
    },
    "open-design": {
      "type": "local",
      "command": [
        "/Applications/Open Design.app/Contents/Resources/open-design/bin/node",
        "/Applications/Open Design.app/Contents/Resources/app/node_modules/@open-design/daemon/dist/cli.js",
        "mcp",
        "--daemon-url",
        "http://127.0.0.1:61430"
      ],
      "enabled": false
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "Gemma 4"
        }
      }
    }
  }
}
